# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
*.egg-info/

# Backend runtime data — never commit real tokens, encryption keys, or the local DB
backend/data/

# Node / frontend
node_modules/
dist/
.vite/

# iOS (Ledger) — .xcodeproj and Info.plist are generated from project.yml via XcodeGen, not hand-edited
ios/Ledger/*.xcodeproj/
ios/Ledger/DerivedData/
ios/Ledger/**/xcuserdata/
ios/Ledger/Ledger/Info.plist

# OS
.DS_Store

# Claude Code local tool settings (per-machine, not project source)
.claude/settings.local.json
